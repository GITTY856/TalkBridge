<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_image"
        android:scaleType="centerCrop"/>

    <!-- Semi-transparent white overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#70FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="52dp"
                android:paddingBottom="6dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/icon"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TalkBridge"
                        android:textColor="#0A1628"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Speech Translator"
                        android:textColor="#1A3276"
                        android:textSize="12sp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="#1A0A1628"
                android:layout_marginBottom="20dp"/>

            <!-- ===== LANGUAGE SELECTOR CARD ===== -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#DDFFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <!-- Source Language Dropdown -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/lang_box_bg"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FROM"
                            android:textColor="#7A94BB"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>

                        <Spinner
                            android:id="@+id/spinnerSourceLang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="#1A3276"
                            android:popupBackground="#FFFFFF"/>

                    </LinearLayout>

                    <!-- Swap Button with Arrow -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp">

                        <Button
                            android:id="@+id/btnSwapLang"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="⇄"
                            android:textSize="20sp"
                            android:backgroundTint="#1A3276"
                            android:textColor="#FFFFFF"
                            android:elevation="2dp"/>

                    </LinearLayout>

                    <!-- Target Language Dropdown -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/lang_box_bg"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TO"
                            android:textColor="#7A94BB"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>

                        <Spinner
                            android:id="@+id/spinnerTargetLang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="#1A3276"
                            android:popupBackground="#FFFFFF"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== YOU SAID CARD ===== -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#DDFFFFFF"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎙  You Said"
                        android:textColor="#0A1628"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="10dp"/>

                    <!-- Outer transparent box -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/outer_box_bg"
                        android:padding="6dp">

                        <!-- Inner semi-transparent box — typeable -->
                        <EditText
                            android:id="@+id/tvSpokenText"
                            android:layout_width="match_parent"
                            android:layout_height="90dp"
                            android:background="@drawable/inner_box_bg"
                            android:padding="12dp"
                            android:hint="Speak or type here..."
                            android:textColorHint="#8A9BB5"
                            android:textColor="#0A1628"
                            android:textSize="15sp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:scrollbars="vertical"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== TRANSLATION CARD ===== -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#DDFFFFFF"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐  Translation"
                        android:textColor="#0A1628"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="10dp"/>

                    <!-- Outer transparent box -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/outer_box_bg"
                        android:padding="6dp">

                        <!-- Inner semi-transparent box -->
                        <TextView
                            android:id="@+id/tvTranslatedText"
                            android:layout_width="match_parent"
                            android:layout_height="90dp"
                            android:background="@drawable/inner_box_bg_blue"
                            android:padding="12dp"
                            android:text="Translation will appear here..."
                            android:textColor="#1A3276"
                            android:textSize="15sp"
                            android:gravity="top"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== STATUS ===== -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Ready"
                android:textColor="#1A5276"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="16dp"/>

            <!-- ===== MIC BUTTON ===== -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A3276"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnMic"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="🎤   HOLD TO SPEAK"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.05"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.AppCompat.Button.Borderless"/>

            </androidx.cardview.widget.CardView>

            <!-- ===== TRANSLATE BUTTON ===== -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#3B6BBF"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnTranslate"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="TRANSLATE  →"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.08"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.AppCompat.Button.Borderless"/>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>